# =============================================================================
# ENG System - Environment Variables Configuration
# =============================================================================
# Copy this file to .env and fill in your values
# NEVER commit .env file to version control
# =============================================================================

# -----------------------------------------------------------------------------
# Server Configuration
# -----------------------------------------------------------------------------
PORT=2005
SERVER_URL=http://localhost:2005
NODE_ENV=development

# -----------------------------------------------------------------------------
# Database Configuration (PostgreSQL)
# -----------------------------------------------------------------------------
DB_HOST=localhost
DB_PORT=5432
DB_NAME=eng_system
DB_USER=eng_admin
DB_PASSWORD=your_password_here
DB_POOL_SIZE=20

# -----------------------------------------------------------------------------
# JWT Secret (Change this in production!)
# -----------------------------------------------------------------------------
JWT_SECRET=your_super_secret_jwt_key_change_in_production_2026

# -----------------------------------------------------------------------------
# Email Configuration - Google Apps Script (Primary Method)
# -----------------------------------------------------------------------------
# GAS Web App URL for email relay
GAS_EMAIL_URL=https://script.google.com/a/macros/minebea.co.th/s/YOUR_DEPLOYMENT_ID/s
GAS_EMAIL_URL_NEW=https://script.google.com/a/macros/minebea.co.th/s/YOUR_NEW_DEPLOYMENT_ID/s
GAS_SECRET_KEY=ENG_DWG_2026

# -----------------------------------------------------------------------------
# Email Configuration - Gmail API (Fallback Method)
# -----------------------------------------------------------------------------
# Get these from Google Cloud Console (Credentials > OAuth 2.0 Client IDs)
GMAIL_CLIENT_ID=your_gmail_client_id.apps.googleusercontent.com
GMAIL_CLIENT_SECRET=your_gmail_client_secret
GMAIL_REDIRECT_URI=http://localhost:2005/auth/google/callback

# Refresh token obtained from OAuth flow (store securely in production)
GMAIL_REFRESH_TOKEN=your_gmail_refresh_token_here

# -----------------------------------------------------------------------------
# Email Recipients - MTC Engineering Workflow
# -----------------------------------------------------------------------------
# Comma-separated list of email addresses for each workflow stage
EMAIL_MTC_ENG_CHECK=engineer1@minebea.co.th,engineer2@minebea.co.th
EMAIL_MTC_DRAFTMAN=draftman1@minebea.co.th,draftman2@minebea.co.th
EMAIL_MTC_DWG_CHECK=dwgchecker1@minebea.co.th,dwgchecker2@minebea.co.th
EMAIL_MTC_ENG_REVIEW=reviewer1@minebea.co.th,reviewer2@minebea.co.th
EMAIL_MTC_ENG_APPROVE=approver1@minebea.co.th,approver2@minebea.co.th
EMAIL_MTC_ENG_INFORM=inform1@minebea.co.th,inform2@minebea.co.th

# -----------------------------------------------------------------------------
# File Upload Configuration
# -----------------------------------------------------------------------------
# Maximum file size in bytes (default: 10MB)
MAX_FILE_SIZE=10485760

# Upload directory (relative to backend root)
UPLOAD_DIR=./files

# -----------------------------------------------------------------------------
# Corporate Proxy (for McAfee Web Gateway)
# -----------------------------------------------------------------------------
# Uncomment and configure if behind corporate proxy
# PROXY_HOST=proxy.minebea.co.th
# PROXY_PORT=8080
# PROXY_USER=your_proxy_username
# PROXY_PASS=your_proxy_password

# -----------------------------------------------------------------------------
# Logging Configuration
# -----------------------------------------------------------------------------
LOG_LEVEL=info
LOG_FILE=./logs/app.log

# -----------------------------------------------------------------------------
# Production-Specific Settings (plbmp129 server)
# -----------------------------------------------------------------------------
# Uncomment these for production deployment
# PORT=2005
# SERVER_URL=http://plbmp129:2005
# NODE_ENV=production
# DB_HOST=localhost
# DB_PORT=5432
# DB_NAME=eng_system
# DB_USER=eng_admin
# DB_PASSWORD=production_password_here
# JWT_SECRET=production_jwt_secret_change_this_2026
