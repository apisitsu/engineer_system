## 🔧 Recommendations

### 1. Add Input Validation
```typescript
import { z } from 'zod';

const RuleSchema = z.object({
  machine_name: z.string().min(1),
  tool_category: z.string().min(1),
  rule_name: z.string().min(1),
  source_field: z.string().min(1),
  operator: z.string().min(1),
  offset_value: z.number(),
  target_tool_table: z.string().min(1),
  target_tool_field: z.string().min(1),
  tolerance_plus: z.number(),
  tolerance_minus: z.number(),
});
```

### 2. Add Rate Limiting
```typescript
import rateLimit from 'express-rate-limit';

const limiter = rateLimit({
  windowMs: 15 * 60 * 1000, // 15 minutes
  max: 100,
});

router.use('/search', limiter);
```

### 3. Add Pagination
```typescript
router.get('/inventory/:tableName', async (req, res) => {
  const { tableName } = req.params;
  const { limit = 10, offset = 0, filter, sort } = req.query;
  const data = await inventoryService.listRecords(
    tableName,
    parseInt(limit as string),
    parseInt(offset as string),
    filter as string | undefined,
    sort as string | undefined
  );
  res.json({ success: true, data, pagination: { limit, offset, total: data.length } });
});
```

### 4. Add Soft Delete
```typescript
router.delete('/inventory/:tableName/:id', isAdmin, async (req, res) => {
  const { tableName, id } = req.params;
  if (!await inventoryService.tableExists(tableName))
    return res.status(400).json({ success: false, error: 'Invalid or unauthorized table' });
  try {
    const deletedId = await inventoryService.softDeleteRecord(tableName, id);
    res.json({ success: true, deletedId });
  } catch (err) {
    console.error('Delete inventory error:', err.message);
    res.status(err.statusCode || 500).json({ success: false, error: err.message });
  }
});
```

### 5. Add Error Codes
```typescript
res.status(400).json({
  success: false,
  error: 'Bad Request',
  code: 'BAD_REQUEST',
  details: err.message,
});
```

